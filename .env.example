# PHP Version (e.g. 8.3, 8.2, 8.1)
PHP_VERSION=8.3

# MariaDB Version (e.g. 11, 10.11, 10.6)
DB_VERSION=11

# Nginx Ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Database
DB_HOST=db
DB_NAME=wordpress
DB_USER=wpuser
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# Domain (used by setup script for SSL)
DOMAIN=yourdomain.com
EMAIL=admin@yourdomain.com
